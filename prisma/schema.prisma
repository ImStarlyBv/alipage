generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum CustomerRole {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PAID
  PENDING_AE_ORDER
  AE_ORDER_PLACED
  AE_ORDER_FAILED
  SHIPPED
  DELIVERED
  REFUNDED
  CANCELLED
}

// ─── Product ─────────────────────────────────────────────

model Product {
  id             String   @id @default(cuid())
  aliexpressId   String   @unique
  title          String
  description    String   @db.Text
  images         Json     // string[]
  categoryId     String?
  category       ImportedCategory? @relation(fields: [categoryId], references: [id])
  basePrice      Decimal  @db.Decimal(10, 2)
  salePrice      Decimal  @db.Decimal(10, 2)
  markup         Decimal  @db.Decimal(5, 2) @default(1.5)
  stock          Int      @default(0)
  variants       Json?    // variantes del producto
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── Customer ────────────────────────────────────────────

model Customer {
  id           String   @id @default(cuid())
  email        String       @unique
  name         String
  passwordHash String?
  role         CustomerRole @default(CUSTOMER)
  addresses    Json?        // array de direcciones
  orders       Order[]
  cart         Cart?
  createdAt    DateTime @default(now())
}

// ─── Order ───────────────────────────────────────────────

model Order {
  id                       String      @id @default(cuid())
  orderNumber              String      @unique @default(cuid())
  customerId               String
  customer                 Customer    @relation(fields: [customerId], references: [id])
  items                    Json        // productos, variantes, cantidades, precios
  shippingAddress          Json?       // customer shipping address for AE order
  totalPaid                Decimal     @db.Decimal(10, 2)
  currency                 String      @default("USD")
  paypalTransactionId      String?
  paypalStatus             String?
  paypalRawResponse        Json?
  aliexpressOrderId        String?
  aliexpressStatus         String?
  aliexpressTrackingNumber String?
  status                   OrderStatus @default(PAID)
  failureReason            String?     @db.Text
  manuallyCompleted        Boolean     @default(false)
  retryCount               Int         @default(0)
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt
  logs                     OrderLog[]
}

// ─── OrderLog ────────────────────────────────────────────

model OrderLog {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  action      String   // e.g. "AE_ORDER_CREATE", "AE_ORDER_RETRY"
  attempt     Int      @default(1)
  requestData Json?    // what was sent to AE
  responseData Json?   // what AE returned
  success     Boolean
  errorMessage String? @db.Text
  createdAt   DateTime @default(now())

  @@index([orderId])
}

// ─── Cart ────────────────────────────────────────────────

model Cart {
  id         String   @id @default(cuid())
  customerId String?  @unique
  customer   Customer? @relation(fields: [customerId], references: [id])
  sessionId  String?  @unique
  items      Json     @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── ImportedCategory ────────────────────────────────────

model ImportedCategory {
  id                   String             @id @default(cuid())
  aliexpressCategoryId String             @unique
  name                 String
  parentId             String?
  parent               ImportedCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children             ImportedCategory[] @relation("CategoryTree")
  products             Product[]
}
